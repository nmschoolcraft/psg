# ============================================================
# PSG Portal — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file with real secrets.
# All production/staging secrets are stored in:
#   - GitHub repository secrets (CI/CD use)
#   - Vercel environment variables (runtime use)
# ============================================================

# ------------------------------------------------------------
# Supabase — Database & Auth
# ------------------------------------------------------------
# Get from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to browser (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase DB connection string (for migrations/seeding)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ------------------------------------------------------------
# Sentry — Error Monitoring
# ------------------------------------------------------------
# Get from: Sentry dashboard → Settings → Projects → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id

# Sentry auth token for source map uploads (CI use only)
# Get from: Sentry → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token

SENTRY_ORG=psg
SENTRY_PROJECT=psg-portal

# ------------------------------------------------------------
# Vercel — Deployment (CI/CD use only, not needed locally)
# ------------------------------------------------------------
# VERCEL_TOKEN — Set in GitHub secrets, not here
# VERCEL_ORG_ID — Set in GitHub secrets, not here
# VERCEL_PROJECT_ID — Set in GitHub secrets, not here

# ------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://portal.psgweb.me

# Node environment
NODE_ENV=development

# ------------------------------------------------------------
# Notifications — ntfy.sh (demo request alerts)
# ------------------------------------------------------------
# Topic name on ntfy.sh — keep this private/unguessable
NTFY_TOPIC=your-private-topic-name

# ------------------------------------------------------------
# Email (Phase 2 — Resend/SendGrid)
# ------------------------------------------------------------
# RESEND_API_KEY=re_your-key-here
# EMAIL_FROM=noreply@psgweb.me

# ------------------------------------------------------------
# LiteLLM Proxy — AI routing (all AI calls go through this)
# ------------------------------------------------------------
# Self-hosted at 128.140.81.55:4000. Virtual keys issued per-app.
# See: ai-infra/litellm-deploy.sh and ai-infra/litellm_config.yaml
LITELLM_URL=http://128.140.81.55:4000
# LITELLM_API_KEY=sk-litellm-your-virtual-key-here   — get from LiteLLM admin
